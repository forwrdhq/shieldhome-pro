# =============================================================================
# ShieldHome Pro — Environment Variables
# =============================================================================

# Database
DATABASE_URL="postgresql://user:pass@host:5432/shieldhome?schema=public"
DIRECT_URL="postgresql://user:pass@host:5432/shieldhome?schema=public"

# NextAuth
NEXTAUTH_SECRET="change-me"
NEXTAUTH_URL="https://shieldhomepro.com"

# App
NEXT_PUBLIC_APP_URL="https://shieldhomepro.com"
NEXT_PUBLIC_PHONE_NUMBER="(877) 555-0199"
NEXT_PUBLIC_PHONE_NUMBER_RAW="+18775550199"

# Twilio
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
REP_PHONE_NUMBERS=""

# SendGrid
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="quotes@shieldhomepro.com"
