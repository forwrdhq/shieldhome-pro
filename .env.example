# =============================================================================
# ShieldHome Pro — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.
# =============================================================================

# --- Database (Required) ---
# Vercel Postgres, Neon, Supabase, or any PostgreSQL connection string
DATABASE_URL="postgresql://user:password@host:5432/shieldhome_pro?sslmode=require"

# --- NextAuth (Required) ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# --- Twilio SMS (Required for SMS features) ---
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-auth-token"
TWILIO_PHONE_NUMBER="+18005551234"

# --- Sales Rep Phone (Required for rep alerts) ---
# The phone number where new lead alerts are sent
REP_PHONE_NUMBER="+15551234567"

# --- SendGrid Email (Required for email features) ---
# Get your API key from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY="SG.xxxxxxxxxxxxxxxxxxxx"
SENDGRID_FROM_EMAIL="quotes@shieldhomepro.com"
SENDGRID_FROM_NAME="ShieldHome Pro"

# --- Cron Job Protection (Required) ---
# Protects cron endpoints from unauthorized access
# Generate with: openssl rand -hex 32
CRON_SECRET="your-cron-secret-here"

# --- Admin Email (Required for daily reports) ---
ADMIN_EMAIL="you@youremail.com"

# --- Slack Notifications (Optional) ---
# Create an Incoming Webhook at https://api.slack.com/messaging/webhooks
# SLACK_WEBHOOK_URL="https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX"

# --- Public Variables (Landing Page) ---
NEXT_PUBLIC_APP_URL="https://shieldhomepro.com"
NEXT_PUBLIC_PHONE_NUMBER="(877) 555-0199"
NEXT_PUBLIC_PHONE_NUMBER_RAW="+18775550199"

# --- Tracking Pixels (Optional) ---
# NEXT_PUBLIC_META_PIXEL_ID="your-pixel-id"
# NEXT_PUBLIC_GOOGLE_ADS_ID="AW-XXXXXXXXXX"
# NEXT_PUBLIC_GOOGLE_CONVERSION_LABEL="your-conversion-label"
