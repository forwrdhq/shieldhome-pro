generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String       @id @default(cuid())
  name          String
  email         String       @unique
  phone         String?
  role          UserRole     @default(REP)
  passwordHash  String
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  activities    Activity[]
  commissions   Commission[]
  assignedLeads Lead[]       @relation("AssignedRep")

  @@map("users")
}

model Lead {
  id                      String            @id @default(cuid())
  firstName               String
  lastName                String
  email                   String?
  phone                   String
  fullName                String
  address                 String?
  city                    String?
  state                   String?
  zipCode                 String?
  propertyType            PropertyType?
  doorsWindows            String?
  productsInterested      String[]
  homeownership           Homeownership?
  timeline                Timeline?
  status                  LeadStatus        @default(NEW)
  leadScore               Int               @default(0)
  priority                Priority          @default(MEDIUM)
  assignedRepId           String?
  source                  String?
  medium                  String?
  campaign                String?
  adSet                   String?
  adId                    String?
  keyword                 String?
  landingPage             String?
  referrer                String?
  utmContent              String?
  gclid                   String?
  fbclid                  String?
  deviceType              String?
  browser                 String?
  ipAddress               String?
  submittedAt             DateTime          @default(now())
  firstContactAt          DateTime?
  speedToContact          Int?
  appointmentDate         DateTime?
  appointmentSat          Boolean           @default(false)
  saleDate                DateTime?
  saleAmount              Float?
  monthlyAmount           Float?
  contractLength          Int?
  emailsSent              Int               @default(0)
  smsSent                 Int               @default(0)
  callsMade               Int               @default(0)
  lastContactDate         DateTime?
  nurtureStep             Int               @default(0)
  nurtureActive           Boolean           @default(true)
  notes                   String?
  dispositionNote         String?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  tcpaConsent             Boolean           @default(false)
  tcpaConsentAt           DateTime?
  currentProvider         String?
  segment                 String?
  contractMonthsRemaining String?
  currentMonthlyPayment   String?
  kwParam                 String?
  creditScoreRange        String?
  activities              Activity[]
  commissions             Commission[]
  emailLogs               EmailLog[]
  assignedRep             User?             @relation("AssignedRep", fields: [assignedRepId], references: [id])
  outreachProspect        OutreachProspect? @relation("OutreachToLead")
  smsLogs                 SmsLog[]
  weeklyDeals             WeeklyDeal[]

  @@index([status])
  @@index([source])
  @@index([assignedRepId])
  @@index([createdAt])
  @@index([submittedAt])
  @@index([segment])
  @@index([email], map: "idx_leads_email")
  @@map("leads")
}

model WeeklyKpi {
  id              String       @id @default(cuid())
  weekStart       DateTime     @unique
  weekEnd         DateTime
  metaSpend       Float        @default(0)
  googleSpend     Float        @default(0)
  otherSpend      Float        @default(0)
  metaCampaigns   Json?
  upfrontReceived Float        @default(0)
  backendReceived Float        @default(0)
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deals           WeeklyDeal[]

  @@index([weekStart])
  @@map("weekly_kpis")
}

model WeeklyDeal {
  id                String    @id @default(cuid())
  weeklyKpiId       String
  leadId            String?
  customerName      String
  vivintAccountIds  String[]
  product           String?
  upfrontCommission Float
  installDate       DateTime?
  notes             String?
  createdAt         DateTime  @default(now())
  weeklyKpi         WeeklyKpi @relation(fields: [weeklyKpiId], references: [id], onDelete: Cascade)
  lead              Lead?     @relation(fields: [leadId], references: [id])

  @@index([weeklyKpiId])
  @@index([leadId])
  @@map("weekly_deals")
}

model Activity {
  id          String       @id @default(cuid())
  leadId      String
  userId      String?
  type        ActivityType
  description String
  metadata    Json?
  createdAt   DateTime     @default(now())
  lead        Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user        User?        @relation(fields: [userId], references: [id])

  @@index([leadId])
  @@index([createdAt])
  @@map("activities")
}

model Commission {
  id              String           @id @default(cuid())
  leadId          String
  repId           String
  saleAmount      Float
  grossCommission Float
  splitPercent    Float            @default(50)
  ourShare        Float
  repShare        Float
  adSpend         Float?
  netProfit       Float?
  status          CommissionStatus @default(PENDING)
  paidDate        DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  lead            Lead             @relation(fields: [leadId], references: [id])
  rep             User             @relation(fields: [repId], references: [id])

  @@index([repId])
  @@index([status])
  @@map("commissions")
}

model EmailLog {
  id         String    @id @default(cuid())
  leadId     String
  type       String
  subject    String
  sendgridId String?
  status     String    @default("sent")
  openedAt   DateTime?
  clickedAt  DateTime?
  sentAt     DateTime  @default(now())
  lead       Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("email_logs")
}

model SmsLog {
  id        String   @id @default(cuid())
  leadId    String
  type      String
  body      String
  twilioSid String?
  status    String   @default("sent")
  sentAt    DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("sms_logs")
}

model Campaign {
  id           String    @id @default(cuid())
  name         String
  source       String
  medium       String
  budget       Float?
  startDate    DateTime?
  endDate      DateTime?
  isActive     Boolean   @default(true)
  totalLeads   Int       @default(0)
  totalSpend   Float     @default(0)
  totalSales   Int       @default(0)
  totalRevenue Float     @default(0)
  cpl          Float?
  cpa          Float?
  roas         Float?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("campaigns")
}

model MetaQuizLead {
  id                 String    @id @default(cuid())
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  firstName          String
  lastName           String?
  email              String?
  phone              String
  zipCode            String?
  quizAnswers        Json
  securityScore      Int
  riskLevel          String
  recommendedPackage String
  urgencyLevel       String
  isHomeowner        Boolean   @default(true)
  propertyType       String?
  hasCurrentSystem   String?
  topConcern         String?
  quizStartedAt      DateTime?
  quizCompletedAt    DateTime?
  contactSubmittedAt DateTime?
  resultsViewedAt    DateTime?
  consultationBooked Boolean   @default(false)
  guideDownloaded    Boolean   @default(false)
  fbclid             String?
  fbp                String?
  fbc                String?
  utmSource          String?   @default("facebook")
  utmMedium          String?   @default("paid")
  utmCampaign        String?
  utmContent         String?
  utmTerm            String?
  utmAdset           String?
  utmAdId            String?
  landingPage        String?
  referrer           String?
  deviceType         String?
  browser            String?
  ipAddress          String?
  userAgent          String?
  status             String    @default("NEW")
  leadScore          Int       @default(0)
  priority           String    @default("MEDIUM")
  notes              String?
  smsToLeadSent      Boolean   @default(false)
  smsToRepSent       Boolean   @default(false)
  emailToLeadSent    Boolean   @default(false)
  slackNotifSent     Boolean   @default(false)
  ghlWebhookSent     Boolean   @default(false)
  smsConsent         Boolean   @default(false)
  tcpaConsent        Boolean   @default(false)
  tcpaConsentAt      DateTime?

  @@index([email])
  @@index([phone])
  @@index([createdAt])
  @@index([status])
  @@index([urgencyLevel])
  @@map("meta_quiz_leads")
}

model OutreachProspect {
  id              String            @id @default(dbgenerated("(gen_random_uuid())::text"))
  email           String            @unique
  firstName       String?
  lastName        String?
  businessName    String
  phone           String?
  website         String?
  nicheSlug       String
  dmaId           String?
  city            String?
  state           String?
  zipCode         String?
  source          String
  instantlyLeadId String?           @unique
  status          String            @default("QUEUED")
  campaignId      String?
  emailsSent      Int               @default(0)
  opensCount      Int               @default(0)
  clicksCount     Int               @default(0)
  repliedAt       DateTime?
  replyLabel      String?
  convertedLeadId String?           @unique
  convertedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @default(now()) @updatedAt
  events          OutreachEvent[]
  campaign        OutreachCampaign? @relation(fields: [campaignId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_prospect_campaign")
  dma             OutreachDMA?      @relation(fields: [dmaId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_prospect_dma")
  convertedLead   Lead?             @relation("OutreachToLead", fields: [convertedLeadId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_prospect_lead")

  @@index([campaignId], map: "idx_outreach_prospects_campaign")
  @@index([createdAt], map: "idx_outreach_prospects_created")
  @@index([dmaId], map: "idx_outreach_prospects_dma")
  @@index([nicheSlug], map: "idx_outreach_prospects_niche")
  @@index([status], map: "idx_outreach_prospects_status")
  @@map("outreach_prospects")
}

model OutreachCampaign {
  id                  String             @id @default(dbgenerated("(gen_random_uuid())::text"))
  name                String
  nicheSlug           String
  dmaId               String?
  instantlyCampaignId String?            @unique
  status              String             @default("DRAFT")
  totalProspects      Int                @default(0)
  totalSent           Int                @default(0)
  totalOpens          Int                @default(0)
  totalClicks         Int                @default(0)
  totalReplies        Int                @default(0)
  totalInterested     Int                @default(0)
  totalConversions    Int                @default(0)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @default(now()) @updatedAt
  dma                 OutreachDMA?       @relation(fields: [dmaId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_campaign_dma")
  prospects           OutreachProspect[]

  @@index([createdAt], map: "idx_outreach_campaigns_created")
  @@index([nicheSlug], map: "idx_outreach_campaigns_niche")
  @@index([status], map: "idx_outreach_campaigns_status")
  @@map("outreach_campaigns")
}

model OutreachDMA {
  id           String                @id
  metroName    String
  states       String[]              @default([])
  isActive     Boolean               @default(true)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @default(now()) @updatedAt
  campaigns    OutreachCampaign[]
  prospects    OutreachProspect[]
  rotationLogs OutreachRotationLog[]

  @@map("outreach_dmas")
}

model OutreachRotationLog {
  id              String      @id @default(dbgenerated("(gen_random_uuid())::text"))
  dmaId           String
  nicheSlug       String
  campaignId      String?
  prospectsQueued Int         @default(0)
  contactedAt     DateTime    @default(now())
  dma             OutreachDMA @relation(fields: [dmaId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_rotation_dma")

  @@index([contactedAt], map: "idx_rotation_contacted")
  @@index([dmaId, nicheSlug], map: "idx_rotation_dma_niche")
  @@map("outreach_rotation_logs")
}

model OutreachEvent {
  id          String            @id @default(dbgenerated("(gen_random_uuid())::text"))
  eventId     String?           @unique
  eventType   String
  prospectId  String?
  campaignId  String?
  payload     Json
  processedAt DateTime?
  createdAt   DateTime          @default(now())
  prospect    OutreachProspect? @relation(fields: [prospectId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_event_prospect")

  @@index([prospectId], map: "idx_outreach_events_prospect")
  @@index([eventType, createdAt], map: "idx_outreach_events_type_created")
  @@map("outreach_events")
}

model SuppressionList {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  email     String   @unique
  reason    String
  source    String
  createdAt DateTime @default(now())

  @@map("suppression_list")
}

enum UserRole {
  ADMIN
  REP
  MANAGER
}

enum PropertyType {
  HOUSE
  TOWNHOME
  CONDO_APARTMENT
  BUSINESS
}

enum Homeownership {
  OWN
  RENT
}

enum Timeline {
  ASAP
  ONE_TWO_WEEKS
  ONE_MONTH
  JUST_RESEARCHING
}

enum LeadStatus {
  NEW
  CONTACTED
  APPOINTMENT_SET
  APPOINTMENT_SAT
  QUOTED
  CLOSED_WON
  CLOSED_LOST
  NO_ANSWER
  NOT_QUALIFIED
  CANCELLED
}

enum Priority {
  HOT
  HIGH
  MEDIUM
  LOW
}

enum ActivityType {
  LEAD_CREATED
  STATUS_CHANGE
  REP_ASSIGNED
  EMAIL_SENT
  SMS_SENT
  CALL_MADE
  CALL_RECEIVED
  APPOINTMENT_SET
  APPOINTMENT_SAT
  APPOINTMENT_MISSED
  NOTE_ADDED
  SALE_CLOSED
  SALE_CANCELLED
  LEAD_SCORED
  NURTURE_EMAIL
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  CLAWBACK
}
